generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Authentication (NextAuth) ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts   Account[]
  sessions   Session[]
  preference UserPreference?
  projects   Project[]
  tasks      Task[]
  scripts    Script[]
  characters Character[]
  locations  Location[]
  voices     Voice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── User Preferences ──────────────────────────────────────────────────────

model UserPreference {
  id     String @id @default(cuid())
  userId String @unique

  // Custom provider list (JSON, API keys encrypted)
  // [{ id, name, baseUrl?, apiKey?, apiMode? }]
  customProviders String? @db.Text

  // Custom model list (JSON)
  // [{ modelId, modelKey, name, type, provider, enabled }]
  customModels String? @db.Text

  // Default model selections (provider::modelId format)
  defaultLlmModel   String?
  defaultImageModel  String?
  defaultVideoModel  String?
  defaultAudioModel  String?

  // TTS voice preference
  ttsVoice String @default("alloy")

  // Defaults
  defaultAspectRatio String @default("16:9")
  defaultStyle       String @default("realistic")
  locale             String @default("zh")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id     String @id @default(cuid())
  userId String

  title       String
  description String? @db.Text
  sourceText  String? @db.LongText

  // Configuration
  style       String @default("realistic")
  aspectRatio String @default("16:9")
  status      String @default("draft") // draft | analyzing | ready | generating | completed

  // Parent-child hierarchy (for import-type master scripts)
  parentId       String?
  masterScriptId String? // links to the master Script that created this project

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentProject Project?    @relation("ProjectChildren", fields: [parentId], references: [id], onDelete: SetNull)
  childProjects Project[]   @relation("ProjectChildren")
  episodes      Episode[]
  characters    Character[]
  locations     Location[]
  tasks         Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([parentId])
  @@index([masterScriptId])
  @@map("projects")
}

// ─── Episodes ───────────────────────────────────────────────────────────────

model Episode {
  id        String @id @default(cuid())
  projectId String

  title    String
  synopsis String?   @db.Text
  sortOrder Int      @default(0)
  status    String   @default("draft") // draft | storyboarded | generating | completed

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clips       Clip[]
  composition Composition?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("episodes")
}

// ─── Clips (Scene Segments) ─────────────────────────────────────────────────

model Clip {
  id        String @id @default(cuid())
  episodeId String

  title       String?
  description String? @db.Text
  dialogue    String? @db.Text
  screenplay  String? @db.Text // Structured screenplay JSON (scenes, action, dialogue, voiceover)
  sortOrder   Int     @default(0)

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  panels  Panel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([episodeId])
  @@map("clips")
}

// ─── Panels (Storyboard Frames) ────────────────────────────────────────────

model Panel {
  id     String @id @default(cuid())
  clipId String

  // Storyboard description
  sceneDescription String? @db.Text
  cameraAngle      String? // close-up | medium | wide | over-shoulder | etc.
  shotType         String? // establishing | action | dialogue | reaction | detail | transition
  cameraMove       String? // static | pan-left | pan-right | tilt-up | tilt-down | zoom-in | zoom-out | dolly | tracking
  imagePrompt      String? @db.Text

  // 4-phase storyboard pipeline data
  sceneType          String?          // daily | emotion | action | epic | suspense
  videoPrompt        String? @db.Text // motion-rich video generation prompt
  sourceText         String? @db.Text // original text excerpt this panel is based on
  photographyRules   String? @db.Text // JSON: lighting, depth_of_field, color_tone, character positions
  actingNotes        String? @db.Text // JSON: per-character acting directions
  candidateImages    String? @db.Text // JSON: array of candidate image URLs
  selectedImageIndex Int     @default(0)
  videoGenerationMode String?         // normal | firstlastframe

  // Asset bindings
  characterIds   String?  @db.Text  // JSON: string[] of character IDs
  locationId     String?            // location ID

  // Generated media URLs
  imageUrl String? @db.MediumText
  videoUrl String? @db.MediumText

  // Timing
  durationMs Int @default(3000)
  sortOrder  Int @default(0)

  clip       Clip        @relation(fields: [clipId], references: [id], onDelete: Cascade)
  voiceLines VoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clipId])
  @@map("panels")
}

// ─── Characters ─────────────────────────────────────────────────────────────

model Character {
  id        String  @id @default(cuid())
  projectId String? // null = global asset
  userId    String?

  name        String
  description String? @db.Text
  imageUrl    String? @db.MediumText

  // Voice configuration
  voiceProvider String? // openai | fish-audio | elevenlabs
  voiceId       String? // provider-specific voice ID
  voiceSample   String? @db.Text // sample audio URL

  // Global voice binding (FK → Voice)
  globalVoiceId String?

  project     Project?              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  globalVoice Voice?                @relation(fields: [globalVoiceId], references: [id], onDelete: SetNull)
  voiceLines  VoiceLine[]
  appearances CharacterAppearance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([globalVoiceId])
  @@map("characters")
}

// ─── Character Appearances ──────────────────────────────────────────────────

model CharacterAppearance {
  id          String @id @default(cuid())
  characterId String

  appearanceIndex Int     @default(0) // 0 = primary
  description     String? @db.Text       // appearance description
  imageUrl        String? @db.MediumText // currently selected image
  candidateImages String? @db.MediumText // JSON: candidate image URL array
  selectedIndex   Int?                // selected candidate index (null=unselected)
  changeReason    String?             // outfit change, time skip, etc.

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, appearanceIndex])
  @@index([characterId])
  @@map("character_appearances")
}

// ─── Locations ──────────────────────────────────────────────────────────────

model Location {
  id        String  @id @default(cuid())
  projectId String? // null = global asset
  userId    String?

  name        String
  description String? @db.Text
  imageUrl    String? @db.MediumText

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@map("locations")
}

// ─── Global Voice Library ───────────────────────────────────────────────────

model Voice {
  id     String @id @default(cuid())
  userId String

  name        String
  description String? @db.Text
  provider    String? // openai | fish-audio | elevenlabs
  voiceId     String? // provider-specific voice ID
  sampleUrl   String? @db.Text // preview audio URL
  gender      String? // male | female | neutral
  language    String  @default("zh")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters Character[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("voices")
}

// ─── Voice Lines ────────────────────────────────────────────────────────────

model VoiceLine {
  id          String  @id @default(cuid())
  panelId     String
  characterId String?

  text     String  @db.Text
  audioUrl String? @db.Text

  // Timing within the panel
  startMs Int @default(0)
  endMs   Int @default(0)

  panel     Panel      @relation(fields: [panelId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([panelId])
  @@map("voice_lines")
}

// ─── Compositions (Video Export Config) ─────────────────────────────────────

model Composition {
  id        String @id @default(cuid())
  episodeId String @unique

  // Settings
  bgmUrl         String? @db.Text
  bgmVolume      Float   @default(0.3)
  subtitleEnabled Boolean @default(true)
  subtitleStyle   String  @default("default") // default | cinematic | minimal
  transition      String  @default("crossfade") // crossfade | cut | fade

  // Output
  outputUrl  String? @db.Text
  srtContent String? @db.LongText
  status     String  @default("pending") // pending | composing | completed | failed
  progress   Int     @default(0)
  error      String? @db.Text

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compositions")
}

// ─── Global Assets ──────────────────────────────────────────────────────────

model AssetFolder {
  id       String  @id @default(cuid())
  parentId String?

  name String

  parent   AssetFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children AssetFolder[] @relation("FolderTree")
  assets   Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("asset_folders")
}

model Asset {
  id       String  @id @default(cuid())
  folderId String?

  name     String
  type     String // image | audio | video | font
  url      String @db.Text
  mimeType String?
  sizeBytes Int?

  folder AssetFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folderId])
  @@map("assets")
}

// ─── Tasks (Job Queue Tracking) ─────────────────────────────────────────────

model Task {
  id        String @id @default(cuid())
  projectId String?
  userId    String

  type    String // ANALYZE_SCRIPT | GENERATE_STORYBOARD | GENERATE_IMAGE | GENERATE_VIDEO | GENERATE_VOICE | COMPOSE_VIDEO | BATCH_GENERATE
  status  String @default("pending") // pending | running | completed | failed
  payload Json?  @db.Json
  result  Json?  @db.Json
  error   String? @db.Text

  // Error classification
  errorCode String?

  // Progress tracking
  progress    Int @default(0)
  totalSteps  Int @default(1)

  // Retry tracking
  attempt     Int @default(0)
  maxAttempts Int @default(3)

  // Heartbeat for watchdog
  heartbeatAt DateTime?

  // BullMQ reference
  bullJobId String?

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  finishedAt  DateTime?
  completedAt DateTime?

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("tasks")
}

// ─── Scripts (剧本库) ─────────────────────────────────────────────────

model Script {
  id     String @id @default(cuid())
  userId String

  title       String
  content     String  @db.LongText
  sourceType  String  @default("manual") // manual | reverse | rewrite | import | chapter
  sourceMedia String? @db.Text           // 原始媒体文件路径（倒推时）
  prompt      String? @db.Text           // 改写要求（改写时）
  parentId    String?                    // 改写来源的 scriptId

  chapterIndex   Int?                    // 章节序号（仅 chapter 类型）
  chapterSummary String?  @db.Text       // 章节摘要
  masterScriptId String?                 // 指向母本（分章关系，区别于 parentId 的改写版本链）
  importMeta     Json?                   // { targetDuration, targetEpisodes, direction, contentType }
  analysisData   Json?                   // 结构化分析（scenes, characters, plotElements, narrativeStructure）

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Script?  @relation("ScriptVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children Script[] @relation("ScriptVersions")

  masterScript Script?  @relation("ScriptChapters", fields: [masterScriptId], references: [id], onDelete: SetNull)
  chapters     Script[] @relation("ScriptChapters")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([masterScriptId])
  @@map("scripts")
}

// ─── Templates ──────────────────────────────────────────────────────────────

model Template {
  id String @id @default(cuid())

  name        String
  description String? @db.Text
  category    String  @default("general") // general | drama | comedy | documentary | ad

  // Template configuration
  style       String @default("realistic")
  aspectRatio String @default("16:9")
  config      Json?  @db.Json // additional template settings

  isPublic Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("templates")
}
