# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:jimeaning123@localhost:13306/jimeaning"

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=16379

# ─── NextAuth ────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret

# ─── Encryption ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string-generate-with-crypto-random

# ─── Storage ─────────────────────────────────────────────────────────────
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data

# ─── Worker Concurrency ─────────────────────────────────────────────────
WORKER_IMAGE_CONCURRENCY=10
WORKER_VIDEO_CONCURRENCY=10
WORKER_VOICE_CONCURRENCY=5
WORKER_TEXT_CONCURRENCY=10
